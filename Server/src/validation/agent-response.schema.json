{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["supported", "unsupported", "irrelevant", "error"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": ["string", "null"]
    },
    "details": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "required": ["type", "message", "tool", "details"],
  "additionalProperties": false,
  "if": {
    "properties": {
      "type": { "const": "supported" }
    }
  },
  "then": {
    "required": ["tool"]
  }
}
